{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [],
  "panels": [
    {
      "title": "gRPC Request Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "sum(rate(grpc_server_requests_total{job=\"x-kv\"}[1m])) by (method, status)",
          "legendFormat": "{{method}} — {{status}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": { "drawStyle": "line", "fillOpacity": 10 }
        }
      }
    },
    {
      "title": "gRPC Latency (p50 / p95 / p99)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(grpc_server_request_duration_seconds_bucket{job=\"x-kv\"}[1m])) by (le, method))",
          "legendFormat": "p50 {{method}}",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(grpc_server_request_duration_seconds_bucket{job=\"x-kv\"}[1m])) by (le, method))",
          "legendFormat": "p95 {{method}}",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(grpc_server_request_duration_seconds_bucket{job=\"x-kv\"}[1m])) by (le, method))",
          "legendFormat": "p99 {{method}}",
          "refId": "C"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "drawStyle": "line", "fillOpacity": 0 }
        }
      }
    },
    {
      "title": "Active Requests",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "grpc_server_active_requests{job=\"x-kv\"}",
          "legendFormat": "{{instance}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "drawStyle": "line", "fillOpacity": 20 }
        }
      }
    },
    {
      "title": "Error Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        {
          "expr": "sum(rate(xkv_errors_total{job=\"x-kv\"}[1m])) by (component, operation)",
          "legendFormat": "{{component}}/{{operation}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": { "drawStyle": "line", "fillOpacity": 10 }
        }
      }
    },
    {
      "title": "gRPC Requests by Status",
      "type": "piechart",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 16 },
      "targets": [
        {
          "expr": "sum(increase(grpc_server_requests_total{job=\"x-kv\"}[5m])) by (status)",
          "legendFormat": "{{status}}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Request Rate by Method",
      "type": "bargauge",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 16 },
      "targets": [
        {
          "expr": "sum(rate(grpc_server_requests_total{job=\"x-kv\"}[5m])) by (method)",
          "legendFormat": "{{method}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "reqps" }
      }
    },
    {
      "title": "Request Duration Heatmap",
      "type": "heatmap",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 16 },
      "targets": [
        {
          "expr": "sum(increase(grpc_server_request_duration_seconds_bucket{job=\"x-kv\"}[1m])) by (le)",
          "legendFormat": "{{le}}",
          "refId": "A",
          "format": "heatmap"
        }
      ]
    }
  ],
  "schemaVersion": 39,
  "tags": ["x-kv"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "title": "x-kv Store Overview",
  "uid": "xkv-overview"
}
