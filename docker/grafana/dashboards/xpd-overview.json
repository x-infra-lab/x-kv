{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [],
  "panels": [
    {
      "title": "PD gRPC Request Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "sum(rate(grpc_server_requests_total{job=\"x-pd\"}[1m])) by (method, status)",
          "legendFormat": "{{method}} — {{status}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": { "drawStyle": "line", "fillOpacity": 10 }
        }
      }
    },
    {
      "title": "PD gRPC Latency (p50 / p95 / p99)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(grpc_server_request_duration_seconds_bucket{job=\"x-pd\"}[1m])) by (le, method))",
          "legendFormat": "p50 {{method}}",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(grpc_server_request_duration_seconds_bucket{job=\"x-pd\"}[1m])) by (le, method))",
          "legendFormat": "p95 {{method}}",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(grpc_server_request_duration_seconds_bucket{job=\"x-pd\"}[1m])) by (le, method))",
          "legendFormat": "p99 {{method}}",
          "refId": "C"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "drawStyle": "line", "fillOpacity": 0 }
        }
      }
    },
    {
      "title": "TSO Request Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "sum(rate(grpc_server_requests_total{job=\"x-pd\", method=~\".*GetTimestamp.*\"}[1m])) by (instance)",
          "legendFormat": "TSO {{instance}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": { "drawStyle": "line", "fillOpacity": 20 }
        }
      }
    },
    {
      "title": "PD Active Requests",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        {
          "expr": "grpc_server_active_requests{job=\"x-pd\"}",
          "legendFormat": "{{instance}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "drawStyle": "line", "fillOpacity": 20 }
        }
      }
    },
    {
      "title": "PD Error Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "targets": [
        {
          "expr": "sum(rate(xkv_errors_total{job=\"x-pd\"}[1m])) by (component, operation)",
          "legendFormat": "{{component}}/{{operation}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": { "drawStyle": "line", "fillOpacity": 10 }
        }
      }
    },
    {
      "title": "Heartbeat Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "targets": [
        {
          "expr": "sum(rate(grpc_server_requests_total{job=\"x-pd\", method=~\".*Heartbeat.*\"}[1m])) by (method)",
          "legendFormat": "{{method}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": { "drawStyle": "line", "fillOpacity": 10 }
        }
      }
    }
  ],
  "schemaVersion": 39,
  "tags": ["x-pd"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "title": "x-pd Placement Driver Overview",
  "uid": "xpd-overview"
